struct Tree {
  .new(depth) {
    var this = struct (Tree) { .depth };
    if (depth > 0) {
      this.a = Tree.new(depth - 1);
      this.b = Tree.new(depth - 1);
      this.c = Tree.new(depth - 1);
      this.d = Tree.new(depth - 1);
      this.e = Tree.new(depth - 1);
    }
    return this;
  },
  ->walk() {
    if (this.depth == 0) return 0;
    return this.depth +
      this.a->walk() +
      this.b->walk() +
      this.c->walk() +
      this.d->walk() +
      this.e->walk();
  },
};

var tree = Tree.new(9);

var start = clock();

for (var i = 0; i < 10; i++) {
  if (tree->walk() != 610_349) throw "error";
}

print(clock() - start);
