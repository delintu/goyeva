print(0 || 1); # out: 1
print(0 || 0); # out: 0
print(1 || 0); # out: 1
print(1 || 1); # out: 1

print(0 && 1); # out: 0
print(0 && 0); # out: 0
print(1 && 0); # out: 0
print(1 && 1); # out: 1

print(0 ?? 1); # out: 0
print(0 ?? 0); # out: 0
print(1 ?? 0); # out: 1
print(1 ?? 1); # out: 1

print(void ?? 1); # out: 1
print(void ?? 0); # out: 0
print(void ?? 0); # out: 0
print(void ?? 1); # out: 1
